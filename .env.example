# Required: a long random string for signing JWT tokens
JWT_SECRET=change_me_to_a_long_random_string

# --- Server ---
PORT=3000                        # Web UI port (default 3000)
MCP_PORT=3001                    # MCP server port (default 3001)
NODE_ENV=production              # Node environment
LOG_LEVEL=info                   # Logging verbosity: error | warn | info | debug

# --- Security ---
JWT_EXPIRY=7d                    # JWT token lifetime (default 7d)
MCP_TOKEN=                       # Optional. If set, overrides the auto-generated MCP token

# --- HTTPS ---
HTTPS_MODE=off                   # off | self-signed | custom
SSL_CERT_PATH=/app/Certs/server.cert   # Path to cert file (required if HTTPS_MODE=custom)
SSL_KEY_PATH=/app/Certs/server.key     # Path to key file (required if HTTPS_MODE=custom)
HOSTNAME=localhost                # Used as CN for self-signed cert

# --- Status Checks ---
CHECK_INTERVAL=60                # Seconds between automatic status checks (default 60)
CHECK_TIMEOUT=2000               # TCP/ping timeout in ms (default 2000)
CHECK_ENABLED=true               # Set to false to disable all background checks globally

# --- App Behaviour ---
SETUP_WIZARD=auto                # auto (show if DB empty) | force (always show) | skip (never show)
MAX_USERS=0                      # Max user accounts allowed, 0 = unlimited
SESSION_TIMEOUT=3600             # Idle session timeout in seconds (default 3600)
