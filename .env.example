# ── Server ────────────────────────────────────────────────────────────────────
# Web UI port (default: 3000)
PORT=3000

# Host/IP to bind the server to (default: 0.0.0.0 = all interfaces)
# Set to 127.0.0.1 to only allow local connections
BIND_HOST=0.0.0.0

# MCP server port (default: 3001)
MCP_PORT=3001

# Node environment: development | production
NODE_ENV=production

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Long random string for signing JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT token lifetime (default: 7d). Examples: 1d, 12h, 7d
JWT_EXPIRY=7d

# MCP Bearer token. If not set, a random token is auto-generated at startup and
# printed to the logs. Set this to a fixed value to make it persistent.
MCP_TOKEN=

# OAuth 2.0 credentials for claude.ai web integration.
# Set these to whatever values you want, then enter the same values in the
# claude.ai Settings → Integrations form (OAuth Client ID / OAuth Client Secret).
MCP_OAUTH_CLIENT_ID=claude-client
MCP_OAUTH_CLIENT_SECRET=

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# HTTPS mode: off | self-signed | custom
# - off:         plain HTTP (default, use a reverse proxy for TLS in production)
# - self-signed: generate a self-signed cert at startup, saved to data/certs/
# - custom:      load cert from SSL_CERT_PATH and SSL_KEY_PATH
HTTPS_MODE=off

# Path to TLS certificate (used when HTTPS_MODE=custom)
SSL_CERT_PATH=/app/data/certs/cert.pem

# Path to TLS private key (used when HTTPS_MODE=custom)
SSL_KEY_PATH=/app/data/certs/key.pem

# Hostname for the self-signed certificate CN (used when HTTPS_MODE=self-signed)
HOSTNAME=localhost

# ── Status Checks ─────────────────────────────────────────────────────────────
# Seconds between automatic background status checks (default: 60)
CHECK_INTERVAL=60

# TCP/ping timeout in milliseconds (default: 2000)
CHECK_TIMEOUT=2000

# Set to false to globally disable all background status checks
CHECK_ENABLED=true

# ── App Behaviour ─────────────────────────────────────────────────────────────
# Setup wizard behaviour: auto | force | skip
# - auto:  show wizard if the database is empty (default)
# - force: always show the wizard on startup (useful for reset)
# - skip:  never show the wizard
SETUP_WIZARD=auto

# Maximum number of user accounts (0 = unlimited)
MAX_USERS=0

# Idle session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Data directory for SQLite DB and generated certs (default: ./data)
DATA_DIR=./data
